# GitHub Personal Access Token (repo, read:user 권한 필요)
# https://github.com/settings/tokens 에서 발급
GITHUB_TOKEN=github_pat_...

# Anthropic API Key (Explainable AI 근거 생성용, 없으면 생략 가능)
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-...

# Polygon Amoy testnet 지갑 개인키 (0x 포함)
# python -c "from web3 import Web3; a=Web3().eth.account.create(); print(a.address, a.key.hex())"
POLYGON_PRIVATE_KEY=0x...

# 배포된 OSSVerifyRegistry 컨트랙트 주소
# python -m ossverify.credential.deploy_contract 실행 후 출력된 값
POLYGON_CONTRACT_ADDRESS=0x...

